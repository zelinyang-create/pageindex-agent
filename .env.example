# ── 入库/建树用的 LLM（OpenAI 兼容端点）──
OPENAI_API_KEY=
OPENAI_API_BASE=https://your-openai-compatible-endpoint/v1
PAGEINDEX_INDEX_MODEL=openai/your-index-model
